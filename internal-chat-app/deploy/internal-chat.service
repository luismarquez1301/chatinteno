[Unit]
Description=Internal Chat FastAPI Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/internal-chat
EnvironmentFile=/opt/internal-chat/.env
ExecStart=/opt/internal-chat/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
